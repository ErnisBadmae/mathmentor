APP_ENV=local
DATABASE_URL=postgresql+psycopg://ege:ege@localhost:5434/ege_mentor
# LAN pilot: "*" lets the phone and parent machine connect. Auth is a header token,
# not cookies, so this is safe. Set a comma-separated list to restrict.
API_CORS_ORIGINS=*
API_SHARED_TOKEN=change-this-family-token
INVITE_BOOTSTRAP_CODE=family-pilot
LOCAL_TIMEZONE=Europe/Moscow

# LLM Provider switch: vllm | llama_cpp (disabled = rule-based manual review)
LLM_PROVIDER=llama_cpp

# llama.cpp server (primary, 192.168.0.18:8000)
LLAMA_CPP_BASE_URL=http://192.168.0.18:8000/v1
LLAMA_CPP_API_KEY=token-abc123
LLAMA_CPP_MODEL=Qwen3.6-35B-A3B-Q5-256K
LLAMA_CPP_TIMEOUT=120

# vllm server (alternative OpenAI-compatible endpoint)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=token-abc123
VLLM_MODEL=qwen-local
VLLM_TIMEOUT=120

TELEGRAM_BOT_TOKEN=
PUBLIC_API_BASE_URL=http://localhost:8001
